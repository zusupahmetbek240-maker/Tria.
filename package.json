{
  "name": "tria",
  "version": "0.1.0",
  "private": true,
  "description": "Adaptive training planner for endurance athletes.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "arch": "depcruise --config .dependency-cruiser.cjs --include-only \"^(app|src)\" --output-type err-long app src",
    "doctor": "expo-doctor",
    "verify": "npm run format:check && npm run typecheck && npm run lint && npm run arch && npm run test"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "expo": "~57.0.6",
    "expo-constants": "~57.0.5",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.6",
    "expo-status-bar": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "29.5.14",
    "@types/react": "^19.2.0",
    "dependency-cruiser": "^18.1.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "expo-doctor": "^1.20.1",
    "jest": "29.7.0",
    "jest-expo": "~57.0.2",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.11",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
