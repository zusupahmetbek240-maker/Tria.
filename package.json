{
  "name": "tria",
  "version": "0.1.0",
  "private": true,
  "description": "Adaptive training planner for endurance athletes.",
  "packageManager": "pnpm@11.9.0",
  "main": "expo-router/entry",
  "scripts": {
    "preinstall": "node scripts/ensure-pnpm.cjs",
    "prepare": "node scripts/configure-git-hooks.cjs",
    "setup:local": "node scripts/setup-local.cjs",
    "preflight": "node scripts/preflight.cjs",
    "env:check": "node scripts/validate-env.cjs",
    "start": "expo start",
    "start:development": "node scripts/with-env.cjs development expo start",
    "start:staging": "node scripts/with-env.cjs staging expo start",
    "start:production": "node scripts/with-env.cjs production expo start",
    "android": "expo start --android",
    "android:development": "node scripts/with-env.cjs development expo start --android",
    "android:staging": "node scripts/with-env.cjs staging expo start --android",
    "android:production": "node scripts/with-env.cjs production expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "config:development": "node scripts/with-env.cjs development expo config --type public",
    "config:staging": "node scripts/with-env.cjs staging expo config --type public",
    "config:production": "node scripts/with-env.cjs production expo config --type public",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "arch": "depcruise --config .dependency-cruiser.cjs --include-only \"^(app|src)\" --output-type err-long app src",
    "doctor": "expo-doctor",
    "ci": "pnpm run verify && pnpm run doctor",
    "release:check": "pnpm install --frozen-lockfile && pnpm run ci && pnpm audit --prod --audit-level moderate",
    "hook:precommit": "node scripts/run-precommit.cjs",
    "precommit": "pnpm run verify",
    "verify": "pnpm run preflight && pnpm run env:check && pnpm run format:check && pnpm run typecheck && pnpm run lint && pnpm run arch && pnpm run test",
    "bootstrap": "pnpm install --frozen-lockfile && pnpm run setup:local && pnpm run ci"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "UNLICENSED",
  "dependencies": {
    "@expo/metro-runtime": "~57.0.6",
    "@sentry/react-native": "~7.11.0",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-status-bar": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "29.5.14",
    "@types/react": "^19.2.0",
    "dependency-cruiser": "^18.1.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "expo-doctor": "^1.20.1",
    "jest": "29.7.0",
    "jest-expo": "~57.0.2",
    "prettier": "^3.9.5",
    "ts-jest": "^29.4.11",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.64.0"
  }
}
